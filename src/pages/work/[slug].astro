---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SpecStrip from '../../components/SpecStrip.astro';
import Scrubber from '../../components/Scrubber.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, cover, gallery, disciplines, video } = project.data;
const { Content } = await render(project);
const tagLabel = disciplines.map((d) => d.toUpperCase()).join(' · ');
---

<BaseLayout title={`${title} — thorno.media`} description={project.data.summary}>
  <article class="wrap detail-page">
    <div class="detail">
      <div class="detail-hero">
        <Image src={cover} alt={title} widths={[640, 1024, 1600, 2000]} sizes="100vw" priority />
        <div class="detail-scrim"></div>
        <div class="detail-info">
          <p class="eyebrow" style="color: rgba(255,255,255,.7)">{tagLabel}</p>
          <h1>{title}</h1>
        </div>
      </div>
      <SpecStrip project={project} />
      <Scrubber project={project} />
    </div>

    <div class="detail-body">
      <Content />
    </div>

    {gallery.length > 0 && (
      <div class="gallery">
        {gallery.map((img) => (
          <Image src={img} alt={title} widths={[400, 800, 1200]} sizes="(max-width: 780px) 100vw, 50vw" />
        ))}
      </div>
    )}

    {video && (
      <div class="video-embed">
        {video.provider === 'youtube' ? (
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${video.id}`}
            title={`${title} — video`}
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        ) : (
          <iframe
            src={`https://player.vimeo.com/video/${video.id}`}
            title={`${title} — video`}
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        )}
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .detail-page { padding: 64px 0 40px; }
  .detail {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface);
  }
  .detail-hero { position: relative; aspect-ratio: 2.39 / 1; }
  .detail-hero :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .detail-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.6), transparent 60%);
  }
  .detail-info { position: absolute; left: 24px; right: 24px; bottom: 20px; z-index: 2; color: #f4f1ec; }
  .detail-info h1 { font-size: clamp(1.3rem, 3vw, 2rem); }

  .detail-body {
    max-width: 68ch;
    margin: 48px auto 0;
    font-size: 1.02rem;
    line-height: 1.7;
  }
  .detail-body :global(p) { margin: 0 0 1.2em; }

  .gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
    margin-top: 48px;
  }
  .gallery :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
  }

  .video-embed {
    margin-top: 48px;
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
