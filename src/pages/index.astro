---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import heroOverhead from '../assets/hero/car-chase-overhead.jpg';
import heroDiagonal from '../assets/hero/car-chase-diagonal.jpg';
import heroTreeTunnel from '../assets/hero/car-chase-tree-tunnel.jpg';
import heroLanops from '../assets/hero/lanops-tent.jpg';
import heroBuhurt from '../assets/hero/buhurt-procession.jpg';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Clips from all 3 source videos, so the hero represents the full range of
// work (FPV, event coverage, combat-sport videography). duration is each
// clip's exact trimmed length (ffprobe format=duration) — Hero.astro uses it
// to size that clip's own hold time, see the prop comment there for why.
// See DESIGN.md decisions log, 2026-07-24.
const heroVideos = [
  { src: '/videos/hero/car-chase-overhead.mp4', poster: heroOverhead.src, duration: 7.490817 },
  { src: '/videos/hero/lanops-tent.mp4', poster: heroLanops.src, duration: 2.7027 },
  { src: '/videos/hero/car-chase-diagonal.mp4', poster: heroDiagonal.src, duration: 7.490817 },
  { src: '/videos/hero/buhurt-procession.mp4', poster: heroBuhurt.src, duration: 5.0 },
  { src: '/videos/hero/car-chase-tree-tunnel.mp4', poster: heroTreeTunnel.src, duration: 7.5075 },
];
---

<BaseLayout title="thorno.media — Photography, Videography, FPV">
  <Hero
    eyebrow="PILOT · PHOTOGRAPHER · VIDEOGRAPHER"
    subtitle="Aerial and ground-based work across photography, film, and FPV, flown, framed, and cut by one hand."
    videos={heroVideos}
    primaryCta={{ label: 'View the work', href: '#work' }}
    secondaryCta={{ label: 'Get in touch', href: '#contact' }}
  >
    Precision in motion,<br />and in stillness.
  </Hero>
  <ProjectGrid projects={projects} />
</BaseLayout>
