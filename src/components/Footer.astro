---
---

<footer id="contact">
  <div class="wrap foot-row">
    <div>
      <div class="logotype"><span class="brand">THORNO</span><span class="dot">.</span><span class="suffix">MEDIA</span></div>
      <p class="foot-note">Based in the UK — available worldwide.</p>
    </div>
    <div class="foot-links">
      <a href="mailto:contact@thorno.media">contact@thorno.media</a>
      <a href="https://instagram.com" target="_blank" rel="noopener noreferrer">Instagram</a>
      <a href="https://youtube.com" target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="https://facebook.com" target="_blank" rel="noopener noreferrer">Facebook</a>
      <a href="https://twitter.com" target="_blank" rel="noopener noreferrer">Twitter</a>
      <a href="https://bsky.app" target="_blank" rel="noopener noreferrer">Bluesky</a>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 60px 0 80px;
    border-top: 1px solid var(--border);
    margin-top: 96px;
  }
  .foot-row {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
  }
  .logotype {
    font-family: 'Archivo Exp', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.01em;
  }
  .logotype .brand { font-weight: 800; }
  .logotype .suffix { font-weight: 400; }
  .logotype .dot { color: var(--accent); font-weight: 400; }
  .foot-note {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin: 8px 0 0;
  }
  .foot-links { display: flex; gap: 20px; font-size: 0.86rem; flex-wrap: wrap; }
  .foot-links a { text-decoration: none; color: var(--text-muted); }
  .foot-links a:hover { color: var(--text); }
</style>
