---
interface Props {
  eyebrow: string;
  subtitle: string;
  // duration must be each clip's exact trimmed length (ffprobe format=duration).
  videos: { src: string; poster: string; duration: number }[];
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
}

const { eyebrow, subtitle, videos, primaryCta, secondaryCta } = Astro.props;

// Crossfade timing: no hold — each clip rises to a single peak at its
// midpoint then immediately falls, so it's always mid-transition into or
// out of the next clip rather than sitting static at full opacity. Fade
// speed is tied to the clip's own length (half its duration each way)
// rather than a shared constant, so the clip plays through its entire
// length exactly once per appearance with no leftover time to freeze on —
// same principle as the old hold-based alignment, just with hold=0.
const fades = videos.map((v) => v.duration / 2);
const TOTAL = fades.reduce((sum, f) => sum + f, 0);
const delays = fades.reduce<number[]>((acc, fade, i) => {
  acc.push(i === 0 ? -fade : acc[i - 1] + fades[i - 1]);
  return acc;
}, []);
const pct = (s: number) => ((s / TOTAL) * 100).toFixed(3);
const crossfadeKeyframes = videos
  .map((v, i) => {
    const fade = fades[i];
    return `
  @keyframes crossfade-${i} {
    0% { opacity: 0; }
    ${pct(fade)}% { opacity: 1; }
    ${pct(fade * 2)}% { opacity: 0; }
    100% { opacity: 0; }
  }`;
  })
  .join('\n');
---

<header class="hero">
  {videos.length > 1 && <style set:html={crossfadeKeyframes} />}
  {
    videos.map(({ src, poster }, i) => (
      <video
        class={videos.length > 1 ? 'hero-bg hero-bg--animated' : 'hero-bg'}
        src={src}
        poster={poster}
        autoplay
        muted
        loop={videos.length === 1}
        playsinline
        aria-hidden="true"
        preload={i === 0 ? 'auto' : 'metadata'}
        style={
          videos.length > 1
            ? `animation-name:crossfade-${i}; animation-duration:${TOTAL}s; animation-delay:${delays[i]}s;`
            : undefined
        }
      />
    ))
  }
  <div class="hero-scrim"></div>
  <div class="hero-frame"></div>
  <div class="lockon"><span class="tl"></span><span class="tr"></span><span class="bl"></span><span class="br"></span></div>
  <div class="wrap hero-content">
    <p class="eyebrow hero-eyebrow">{eyebrow}</p>
    <h1><slot /></h1>
    <p class="hero-sub">{subtitle}</p>
    <div class="hero-actions">
      <a class="btn btn-primary" href={primaryCta.href}>{primaryCta.label}</a>
      <a class="btn hero-btn-secondary" href={secondaryCta.href}>{secondaryCta.label}</a>
    </div>
  </div>
</header>

<script>
  // prefers-reduced-motion must freeze on the first clip's poster, not just stop
  // crossfading between clips — CSS alone can hide the others, but only JS can
  // stop this one's own internal video playback.
  const mql = window.matchMedia('(prefers-reduced-motion: reduce)');
  const videos = document.querySelectorAll('.hero-bg--animated');
  const freeze = () => {
    if (!mql.matches) return;
    videos.forEach((video, i) => {
      video.pause();
      if (i === 0) video.currentTime = 0;
    });
  };
  freeze();
  mql.addEventListener('change', freeze);

  // Resync each clip's playback to frame 0 exactly when its own crossfade
  // cycle restarts (local 0%, i.e. the instant its fade-in begins), instead
  // of trusting the browser's native <video loop> to independently stay in
  // phase with the CSS animation. An earlier attempt did this with a JS
  // setTimeout/setInterval schedule computed from script-execution time —
  // that still drifted, because inline <script> runs during HTML parsing
  // (before first paint) while the CSS animation's own clock only starts at
  // paint, so the two timers had different t=0 references. Using
  // animationstart/animationiteration instead ties the reset directly to the
  // browser's own animation clock — the same clock driving opacity — so
  // there's no separate timer to drift out of phase with it. See DESIGN.md
  // decisions log, 2026-07-24.
  videos.forEach((video) => {
    const resync = () => {
      video.currentTime = 0;
      if (video.paused) video.play().catch(() => {});
    };
    video.addEventListener('animationstart', resync);
    video.addEventListener('animationiteration', resync);
  });
</script>

<style>
  .hero {
    position: relative;
    height: calc(100vh - var(--nav-height));
    height: calc(100dvh - var(--nav-height));
    min-height: 480px;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: #14181a;
  }
  .hero .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero .hero-bg--animated {
    opacity: 0;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero .hero-bg--animated { animation: none; opacity: 0; }
    .hero .hero-bg--animated:first-child { opacity: 1; }
  }
  .hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(0deg, rgba(11, 13, 15, 0.92) 0%, rgba(11, 13, 15, 0.25) 46%, rgba(11, 13, 15, 0.15) 70%);
  }
  .hero-frame {
    position: absolute;
    inset: 22px;
    border: 1px solid rgba(255, 255, 255, 0.14);
    pointer-events: none;
  }
  .lockon { position: absolute; inset: 22px; pointer-events: none; }
  .lockon span {
    position: absolute;
    width: 26px;
    height: 26px;
    border-color: var(--accent);
    opacity: 0;
    animation: lockon-in 1.1s cubic-bezier(0.2, 0.7, 0.3, 1) 0.15s forwards;
  }
  .lockon .tl { top: -1px; left: -1px; border-top: 2px solid; border-left: 2px solid; }
  .lockon .tr { top: -1px; right: -1px; border-top: 2px solid; border-right: 2px solid; }
  .lockon .bl { bottom: -1px; left: -1px; border-bottom: 2px solid; border-left: 2px solid; }
  .lockon .br { bottom: -1px; right: -1px; border-bottom: 2px solid; border-right: 2px solid; }
  @keyframes lockon-in {
    from { opacity: 0; transform: scale(1.6); }
    to { opacity: 1; transform: scale(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .lockon span { animation: none; opacity: 1; }
  }

  .hero-content { position: relative; z-index: 2; width: 100%; }
  .hero-eyebrow { color: rgba(255, 255, 255, 0.62); margin-bottom: 18px; }
  .hero h1 {
    color: #f4f1ec;
    font-size: clamp(2.2rem, 6vw, 4.6rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    max-width: 15ch;
  }
  .hero-sub {
    color: rgba(255, 255, 255, 0.72);
    font-size: 1.05rem;
    max-width: 46ch;
    margin-top: 20px;
    line-height: 1.55;
  }
  .hero-actions { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
  .hero-btn-secondary { background: transparent; color: #f4f1ec; border-color: rgba(255, 255, 255, 0.35); }
  .hero-btn-secondary:hover { border-color: #f4f1ec; }
</style>
