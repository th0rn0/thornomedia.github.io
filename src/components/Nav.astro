---
---

<nav class="top">
  <div class="wrap row">
    <a class="logotype" href="/"><span class="brand">THORNO</span><span class="dot">.</span><span class="suffix">MEDIA</span></a>
    <div class="navlinks">
      <a href="/#work">Work</a>
      <a href="/#contact">Contact</a>
    </div>
  </div>
</nav>

<style>
  nav.top {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px) saturate(1.1);
    border-bottom: 1px solid var(--border);
  }
  nav.top .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
  }
  .logotype {
    font-family: 'Archivo Exp', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 0.01em;
    text-decoration: none;
  }
  .logotype .brand { font-weight: 800; }
  .logotype .suffix { font-weight: 400; }
  .logotype .dot { color: var(--accent); font-weight: 400; }
  .navlinks { display: flex; align-items: center; gap: 28px; font-size: 0.88rem; }
  .navlinks a { text-decoration: none; color: var(--text-muted); transition: color 0.15s ease; }
  .navlinks a:hover, .navlinks a:focus-visible { color: var(--text); }
  .navlinks a:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 2px; }

  @media (max-width: 420px) {
    .navlinks { gap: 14px; }
  }
</style>
